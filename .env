# Postgres
DB_NAME=a4s
DB_USER=postgres_user
DB_PASSWORD=postgres_password
DB_HOST=postgres
DB_PORT=5432


# Minio
S3_URL=http://minio:9000
S3_USER=S3_USER
S3_PASSWORD=S3_PASSWORD
S3_DATASETS_BUCKET=datasets
S3_MODELS_BUCKET=models


# RabbitMQ
MQ_HOST=rabbitmq
MQ_USERNAME=rabbit_user
MQ_PASSWORD=rabbit_password
MQ_USE_SSL=false
MQ_PORT=5672


# Reddis
REDIS_HOST=redis
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_USE_SSL=false
REDIS_PORT=6379


# backend
APP_NAME=a4s-backend
DJANGO_SECRET_KEY=your_secret_key
DB_ENGINE=django.db.backends.postgresql
DEBUG=False
LOG_LEVEL=INFO
EVAL_URL=http://eval:8001
EVAL_PREFIX=/api/v1


# eval
API_URL=http://backend:8000
API_PREFIX=/api/v1
CACHE_DIR=/tmp/cache


# webapp
VITE_API_URL=http://127.0.0.1:8000
CORS_ORIGINS=*

API_URL_EXTERNAL=http://localhost:8000