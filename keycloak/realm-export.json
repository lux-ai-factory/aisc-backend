{
  "realm": "a4s",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "a4s-backend",
      "name": "A4S Backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "a4s-dev-secret",
      "redirectUris": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*",
        "http://localhost/*",
        "http://localhost:5173/*",
        "http://host.docker.internal:5173/*",
        "http://host.docker.internal:8000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://host.docker.internal:5173",
        "http://host.docker.internal:8000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "email": "testuser@a4s.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
